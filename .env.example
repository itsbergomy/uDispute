# ─── uDispute Environment Variables ───
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ──

# Flask secret key (REQUIRED in production)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# OpenAI API key (required for AI analysis and letter generation)
OPENAI_API_KEY=sk-...

# ── Optional (features degrade gracefully without these) ──

# DocuPost API token (required for mailing letters)
DOCUPOST_API_TOKEN=your-docupost-token

# Set to "true" to skip actual mailing (logs what would be sent)
DOCUPOST_DRY_RUN=true

# Public base URL for your app (used to generate PDF URLs for DocuPost)
APP_BASE_URL=http://127.0.0.1:5001

# Upload directory for client files
UPLOAD_FOLDER=static/uploads

# Stripe keys (for payment processing)
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_...
STRIPE_TEST_SECRET_KEY=sk_test_...

# Cloudinary (for cloud file storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email (for sending analysis reports)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Environment (set to "development" for debug mode locally)
FLASK_ENV=development
